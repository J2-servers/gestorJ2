generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  reseller
  dev
  recovery
}

enum UserStatus {
  active
  blocked
  invited
}

enum PaymentType {
  prepaid
  postpaid
}

enum RequestStatus {
  pending
  analyzing
  recharged
  rejected
  canceled
}

enum ApprovalStatus {
  pending
  approved
  rejected
  analyzing
}

enum NotificationType {
  system
  queue
  new_request
  approval
  rejection
  invoice
  whatsapp
}

enum InvoiceStatus {
  pending
  paid
  overdue
  canceled
}

enum WhatsAppLogStatus {
  queued
  sent
  failed
}

enum RechargeCodeStatus {
  available
  reserved
  sold
  voided
}

enum SupportTopicStatus {
  draft
  published
  archived
}

enum SupportServerStatus {
  operational
  attention
  maintenance
  degraded
  offline
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  passwordHash    String?
  name            String
  phone           String?
  profileImageUrl String?
  role            UserRole             @default(reseller)
  status          UserStatus           @default(active)
  paymentType     PaymentType          @default(prepaid)
  parentId        String?
  parent          User?                @relation("AdminResellers", fields: [parentId], references: [id], onDelete: SetNull)
  resellers       User[]               @relation("AdminResellers")
  creditRequests  CreditRequest[]      @relation("ResellerRequests")
  approvals       ApprovalStage[]      @relation("ApprovalUser")
  notifications   Notification[]
  resellerServers ResellerServer[]
  invoices        Invoice[]
  auditLogs       AuditLog[]
  pushSubs        PushSubscription[]
  messages        RequestMessage[]     @relation("MessageAuthor")
  templates       MessageTemplate[]    @relation("TemplateOwner")
  ownedServers    Server[]             @relation("ServerOwner")
  chatMessages    ChatMessage[]        @relation("ResellerChat")
  priceChanges    ServerPriceHistory[]
  refreshTokens   RefreshToken[]
  codeBatches      RechargeCodeBatch[]  @relation("CodeBatchImporter")
  soldCodes        RechargeCode[]       @relation("CodeBuyer")
  supportTopics    SupportTopic[]       @relation("SupportTopicAuthor")
  supportLinks     SupportLink[]        @relation("SupportLinkAuthor")
  supportUpdates   SupportServerUpdate[] @relation("SupportUpdateAuthor")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([role])
  @@index([parentId])
}

model Server {
  id                  String               @id @default(cuid())
  name                String
  panelLink           String?
  costPerCredit       Decimal              @db.Decimal(12, 4)
  valuePerCredit      Decimal              @db.Decimal(12, 4)
  ownerId             String?
  owner               User?                @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  active              Boolean              @default(true)
  notes               String?
  deletedAt           DateTime?
  resellerServers     ResellerServer[]
  suppliers           Supplier[]
  serverFornecedores  ServerFornecedor[]
  priceHistory        ServerPriceHistory[]
  codeProducts        RechargeCodeProduct[]
  supportTopics       SupportTopic[]
  supportLinks        SupportLink[]
  supportUpdates      SupportServerUpdate[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([active])
  @@index([deletedAt])
  @@index([ownerId])
}

model SupportTopic {
  id          String             @id @default(cuid())
  serverId    String?
  server      Server?            @relation(fields: [serverId], references: [id], onDelete: SetNull)
  title       String
  category    String
  summary     String?
  content     String?
  steps       Json?
  status      SupportTopicStatus @default(published)
  pinned      Boolean            @default(false)
  sortOrder   Int                @default(0)
  authorId    String?
  author      User?              @relation("SupportTopicAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, pinned, sortOrder])
  @@index([serverId, status])
  @@index([category])
  @@index([authorId])
}

model SupportLink {
  id          String             @id @default(cuid())
  serverId    String?
  server      Server?            @relation(fields: [serverId], references: [id], onDelete: SetNull)
  label       String
  href        String
  category    String
  detail      String?
  status      SupportTopicStatus @default(published)
  pinned      Boolean            @default(false)
  sortOrder   Int                @default(0)
  authorId    String?
  author      User?              @relation("SupportLinkAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, pinned, sortOrder])
  @@index([serverId, status])
  @@index([category])
  @@index([authorId])
}

model SupportServerUpdate {
  id          String              @id @default(cuid())
  serverId    String?
  server      Server?             @relation(fields: [serverId], references: [id], onDelete: SetNull)
  title       String
  message     String
  status      SupportServerStatus @default(operational)
  impact      String?
  actionText  String?
  pinned      Boolean             @default(false)
  published   Boolean             @default(true)
  authorId    String?
  author      User?               @relation("SupportUpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([published, pinned, createdAt])
  @@index([serverId, createdAt])
  @@index([authorId])
}

model RechargeCodeProduct {
  id           String              @id @default(cuid())
  name         String
  description  String?
  serverId     String?
  server       Server?             @relation(fields: [serverId], references: [id], onDelete: SetNull)
  denomination Int
  costValue    Decimal             @default(0) @db.Decimal(12, 2)
  saleValue    Decimal             @db.Decimal(12, 2)
  instructions String?
  active       Boolean             @default(true)
  batches      RechargeCodeBatch[]
  codes        RechargeCode[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([active])
  @@index([serverId])
}

model RechargeCodeBatch {
  id             String              @id @default(cuid())
  productId      String
  product        RechargeCodeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  importedById   String?
  importedBy     User?               @relation("CodeBatchImporter", fields: [importedById], references: [id], onDelete: SetNull)
  sourceFilename String?
  notes          String?
  totalRows      Int                 @default(0)
  importedCount  Int                 @default(0)
  duplicateCount Int                 @default(0)
  invalidCount   Int                 @default(0)
  createdAt      DateTime            @default(now())
  codes          RechargeCode[]

  @@index([productId, createdAt])
  @@index([importedById])
}

model RechargeCode {
  id         String              @id @default(cuid())
  productId  String
  product    RechargeCodeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchId    String?
  batch      RechargeCodeBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  code       String              @unique
  pin        String?
  serial     String?
  status     RechargeCodeStatus  @default(available)
  expiresAt  DateTime?
  soldToId   String?
  soldTo     User?               @relation("CodeBuyer", fields: [soldToId], references: [id], onDelete: SetNull)
  soldAt     DateTime?
  reservedAt DateTime?
  voidReason String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([productId, status])
  @@index([batchId])
  @@index([soldToId])
  @@index([createdAt])
}

// Fornecedor de um servidor: cada servidor pode ter varios fornecedores,
// cada um com seu proprio login no painel e seu custo. O admin liga cada
// revendedor (ResellerServer) a um fornecedor de forma invisivel ao revendedor.
// NOTA: Este modelo e LEGADO. Use Fornecedor + ServerFornecedor para novos vinculos.
model Supplier {
  id              String           @id @default(cuid())
  serverId        String
  server          Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name            String
  panelLogin      String
  panelLink       String?
  costPerCredit   Decimal          @db.Decimal(12, 4)
  active          Boolean          @default(true)
  resellerServers ResellerServer[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([serverId])
}

// Fornecedor standalone: entidade independente que pode ser vinculado a N servidores.
// Cada vinculo (ServerFornecedor) tem seus proprios dados de custo, login e painel.
model Fornecedor {
  id                String             @id @default(cuid())
  name              String
  contact           String?
  notes             String?
  active            Boolean            @default(true)
  serverFornecedores ServerFornecedor[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([active])
}

// Vinculo entre Servidor e Fornecedor: cada servidor pode ter varios fornecedores,
// e cada fornecedor pode estar em varios servidores. Cada vinculo tem dados proprios
// (custo, login, link de painel) porque o mesmo servidor pode ser comprado de
// fornecedores diferentes, com precos e logins diferentes.
model ServerFornecedor {
  id               String    @id @default(cuid())
  serverId         String
  server           Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  fornecedorId     String
  fornecedor       Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  costPerCredit    Decimal   @db.Decimal(12, 4)
  panelLogin       String
  panelLink        String?
  panelPassword    String?
  notes            String?
  active           Boolean   @default(true)
  resellerServers  ResellerServer[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([serverId, fornecedorId])
  @@index([serverId])
  @@index([fornecedorId])
}

model ServerPriceHistory {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  oldPrice    Decimal? @db.Decimal(12, 4)
  newPrice    Decimal  @db.Decimal(12, 4)
  changedById String?
  changedBy   User?    @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([serverId, createdAt])
  @@index([changedById])
}

model ResellerServer {
  id             String    @id @default(cuid())
  resellerId     String
  serverId       String
  login          String
  valuePerCredit Decimal   @db.Decimal(12, 4)
  active         Boolean   @default(true)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  serverFornecedorId String?
  serverFornecedor ServerFornecedor? @relation(fields: [serverFornecedorId], references: [id], onDelete: SetNull)
  reseller       User      @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  server         Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([resellerId, serverId, login])
  @@index([resellerId])
  @@index([serverId])
  @@index([supplierId])
  @@index([serverFornecedorId])
}

// Arquivo (empacotamento) de conversas: ao "empacotar", as mensagens da thread
// sao compactadas (gzip) aqui e removidas da tabela viva, mantendo o historico
// permanente sem sobrecarregar o chat ativo.
model ChatArchive {
  id           String    @id @default(cuid())
  resellerId   String
  messageCount Int
  fromDate     DateTime?
  toDate       DateTime?
  gzipData     Bytes
  createdById  String
  createdAt    DateTime  @default(now())

  @@index([resellerId, createdAt])
}

// Chat direto admin <-> revendedor. Uma thread por revendedor (resellerId).
// Isolamento: o revendedor so acessa a propria thread; o admin acessa as de
// seus revendedores (e orfaos). authorId/authorName = quem escreveu.
model ChatMessage {
  id             String   @id @default(cuid())
  resellerId     String
  reseller       User     @relation("ResellerChat", fields: [resellerId], references: [id], onDelete: Cascade)
  authorId       String
  authorName     String
  authorRole     String
  content        String
  readByAdmin    Boolean  @default(false)
  readByReseller Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([resellerId, createdAt])
}

model CreditRequest {
  id               String           @id @default(cuid())
  resellerId       String
  reseller         User             @relation("ResellerRequests", fields: [resellerId], references: [id], onDelete: Restrict)
  serverId         String?
  serverSnapshot   Json
  supplierSnapshot Json?
  requestedCredits Int
  login            String
  totalValue       Decimal          @db.Decimal(12, 2)
  proofUrl         String?
  notes            String?
  status           RequestStatus    @default(pending)
  paymentType      PaymentType
  rejectionReason  String?
  currentStage     Int              @default(2)
  hasMaster        Boolean          @default(false)
  approvalStages   ApprovalStage[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  whatsappLogs     WhatsAppLog[]
  messages         RequestMessage[]
  invoiceId        String?
  invoice          Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([resellerId])
  @@index([status])
  @@index([createdAt])
  @@index([invoiceId])
}

model ApprovalStage {
  id              String         @id @default(cuid())
  creditRequestId String
  creditRequest   CreditRequest  @relation(fields: [creditRequestId], references: [id], onDelete: Cascade)
  stageNumber     Int
  approverRole    UserRole
  approverId      String?
  approver        User?          @relation("ApprovalUser", fields: [approverId], references: [id], onDelete: SetNull)
  status          ApprovalStatus @default(pending)
  notes           String?
  createdById     String?
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([creditRequestId])
  @@index([approverId])
}

model RequestMessage {
  id              String        @id @default(cuid())
  creditRequestId String
  creditRequest   CreditRequest @relation(fields: [creditRequestId], references: [id], onDelete: Cascade)
  authorId        String
  author          User          @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  content         String
  createdAt       DateTime      @default(now())

  @@index([creditRequestId])
  @@index([authorId])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("TemplateOwner", fields: [adminId], references: [id], onDelete: Cascade)
  name      String
  type      String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([type])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message         String
  type            NotificationType @default(system)
  relatedEntityId String?
  creditRequestId String?
  creditRequest   CreditRequest?   @relation(fields: [creditRequestId], references: [id], onDelete: Cascade)
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id              String         @id @default(cuid())
  creditRequestId String?
  creditRequest   CreditRequest? @relation(fields: [creditRequestId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName        String
  action          String
  details         String?
  ipAddress       String?
  createdAt       DateTime       @default(now())

  @@index([creditRequestId])
  @@index([createdAt])
}

model Invoice {
  id         String          @id @default(cuid())
  resellerId String
  reseller   User            @relation(fields: [resellerId], references: [id], onDelete: Restrict)
  status     InvoiceStatus   @default(pending)
  totalValue Decimal         @db.Decimal(12, 2)
  dueDate    DateTime?
  paidAt     DateTime?
  proofUrl   String?
  requests   CreditRequest[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([resellerId])
  @@index([status])
  @@index([dueDate])
}

model Settings {
  id                      String   @id @default(cuid())
  adminId                 String
  companyName             String   @default("Gestor J2")
  cnpj                    String?
  address                 String?
  phone                   String?
  email                   String?
  faviconUrl              String?
  sidebarLogoUrl          String?
  sidebarLogoFit          String?
  profileIconUrl          String?
  loginLogoUrl            String?
  loginLogoFit            String?
  loginBackgroundUrl      String?
  loginBackgroundPosition String?
  loginBrandSubtitle      String?
  loginHeroEyebrow        String?
  loginHeroTitle          String?
  loginHeroText           String?
  loginPanelEyebrow       String?
  loginPanelTitle         String?
  loginLoginTabText       String?
  loginRegisterTabText    String?
  loginSubmitText         String?
  loginRegisterSubmitText String?
  loginStatusText         String?
  adminWhatsapp           String?
  whatsappProvider        String   @default("evolution")
  whatsappEnabled         Boolean  @default(true)
  evolutionApiUrl         String?
  evolutionInstance       String?
  evolutionApiKeyRef      String?
  n8nWebhookUrl           String?
  fcmServerKey            String?
  pixKeys                 Json     @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([adminId])
}

model WhatsAppLog {
  id              String            @id @default(cuid())
  phone           String
  messagePreview  String
  status          WhatsAppLogStatus @default(queued)
  attempts        Int               @default(0)
  responseData    Json?
  relatedEntityId String?
  creditRequestId String?
  creditRequest   CreditRequest?    @relation(fields: [creditRequestId], references: [id], onDelete: SetNull)
  executionTimeMs Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([relatedEntityId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  keys      Json
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ErrorLog {
  id         String   @id @default(cuid())
  level      String   @default("error") // error | warn
  statusCode Int?
  method     String?
  path       String?
  message    String
  stack      String?
  context    String?
  userId     String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([resolved])
  @@index([userId])
}
