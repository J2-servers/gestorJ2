{
  "name": "gestor-j2-frontend-vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run --environment jsdom --passWithNoTests",
    "test:watch": "vitest --environment jsdom"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@vee-validate/zod": "^4.15.1",
    "chart.js": "^4.5.1",
    "pinia": "^2.3.1",
    "socket.io-client": "^4.8.3",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  }
}
