# Gestor J2 - exemplo local para docker compose

FRONTEND_ORIGIN=http://localhost:8080
WEB_PORT=8080
BACKEND_UPSTREAM=backend:3333

POSTGRES_DB=gestorj2
POSTGRES_USER=gestorj2
POSTGRES_PASSWORD=gestorj2-local

JWT_SECRET=troque-por-um-segredo-local-com-32-caracteres
JWT_EXPIRES_IN=1d

EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=gestorj2

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gestorj2.local

MAX_UPLOAD_MB=10
SEED_ON_START=false
SEED_ADMIN_PASSWORD=
SEED_RECOVERY_PASSWORD=
SEED_RESELLER_PASSWORD=
SEED_RESET_PASSWORDS=false
