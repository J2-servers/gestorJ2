{
  "name": "gestor-j2",
  "private": true,
  "version": "1.0.0",
  "description": "Gestor J2 - backend NestJS, frontend Vue e deploy Docker/EasyPanel.",
  "scripts": {
    "dev": "npm run frontend:dev",
    "build": "npm run frontend:build",
    "typecheck": "npm run frontend:typecheck",
    "test": "npm run frontend:test",
    "frontend:install": "npm install --prefix frontend-vue",
    "frontend:dev": "npm run dev --prefix frontend-vue",
    "frontend:build": "npm run build --prefix frontend-vue",
    "frontend:typecheck": "npm run typecheck --prefix frontend-vue",
    "frontend:test": "npm run test --prefix frontend-vue",
    "backend:install": "npm install --prefix backend",
    "backend:dev": "npm run dev --prefix backend",
    "backend:build": "npm run build --prefix backend",
    "backend:prisma:generate": "npm run prisma:generate --prefix backend",
    "backend:prisma:migrate": "npm run prisma:migrate --prefix backend",
    "backend:prisma:seed": "npm run prisma:seed --prefix backend",
    "icons": "node scripts/generate-icons.cjs",
    "infra:dev": "docker compose up -d --build",
    "verify": "npm run frontend:build && npm run backend:build",
    "audit:prod": "npm audit --omit=dev --prefix frontend-vue && npm audit --omit=dev --prefix backend"
  }
}
