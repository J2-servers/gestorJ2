# Gestor J2 - variaveis de producao
# Copie para .env no EasyPanel/Compose e preencha.
# Nunca versione o .env real.

# Dominio publico do frontend. Usado no CORS do backend.
FRONTEND_ORIGIN=https://app.seudominio.com

# Porta local do frontend quando usar docker compose fora do EasyPanel.
WEB_PORT=8080

# Nome interno do backend para o Nginx do frontend.
# No docker-compose deste projeto, use backend:3333.
BACKEND_UPSTREAM=backend:3333

# Postgres
POSTGRES_DB=gestorj2
POSTGRES_USER=gestorj2
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte

# Seguranca
# Gere com: openssl rand -hex 32
# Nao use URL aqui.
JWT_SECRET=TROQUE_por_um_segredo_aleatorio_com_32_chars_ou_mais
JWT_EXPIRES_IN=1d

# WhatsApp / Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=gestorj2
WHATSAPP_MIN_DELAY_MS=15000
WHATSAPP_MAX_DELAY_MS=75000
WHATSAPP_MIN_SEND_INTERVAL_MS=20000
WHATSAPP_RETRY_BASE_DELAY_MS=120000
WHATSAPP_MAX_PER_MINUTE=3

# Web Push / PWA
# Gere com: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seudominio.com

# Uploads
MAX_UPLOAD_MB=10

# Seed inicial
# Use true apenas no primeiro deploy. Depois volte para false.
SEED_ON_START=false
SEED_ADMIN_PASSWORD=
SEED_RECOVERY_PASSWORD=
SEED_RESELLER_PASSWORD=
SEED_RESET_PASSWORDS=false
