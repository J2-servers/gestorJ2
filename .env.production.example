# â”€â”€â”€â”€â”€â”€â”€â”€â”€ Gestor J2 â€” variÃ¡veis de produÃ§Ã£o â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Copie para .env (ao lado do docker-compose.yml) e preencha.
# NUNCA versione o .env real.

# DomÃ­nio pÃºblico do frontend (usado no CORS do backend).
# Ex.: https://app.seudominio.com
FRONTEND_ORIGIN=https://app.seudominio.com

# Porta pÃºblica do frontend (ignorada no EasyPanel, que usa o proxy prÃ³prio).
WEB_PORT=8080

# â”€â”€ Banco de dados (Postgres) â”€â”€
POSTGRES_DB=gestorj2
POSTGRES_USER=gestorj2
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte

# â”€â”€ SeguranÃ§a â”€â”€
# Gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_por_um_segredo_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=1d

# â”€â”€ WhatsApp (Evolution API) â€” opcional â”€â”€
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=gestorj2
WHATSAPP_MIN_DELAY_MS=15000
WHATSAPP_MAX_DELAY_MS=75000
WHATSAPP_MIN_SEND_INTERVAL_MS=20000
WHATSAPP_RETRY_BASE_DELAY_MS=120000
WHATSAPP_MAX_PER_MINUTE=3

# â”€â”€ Web Push (VAPID) â€” OBRIGATÃ“RIO para notificaÃ§Ãµes com tela apagada â”€â”€
# Gere uma vez com: docker compose run --rm backend node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seudominio.com

# â”€â”€ Uploads â”€â”€
MAX_UPLOAD_MB=10

# â”€â”€ Seed inicial â”€â”€
# Deixe SEED_ON_START=true APENAS no primeiro deploy para criar admin, recovery e revendedor demo.
# Depois volte para false.
SEED_ON_START=false
# Admin operacional (faz tudo) e conta de recuperaÃ§Ã£o (sÃ³ troca credenciais do operacional).
SEED_ADMIN_PASSWORD=
SEED_RECOVERY_PASSWORD=
SEED_RESELLER_PASSWORD=
SEED_RESET_PASSWORDS=false

